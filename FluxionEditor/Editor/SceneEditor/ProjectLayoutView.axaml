<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:components="using:FluxionEditor.Foundation.Components"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FluxionEditor.ProjectLayoutView"
             x:DataType="foundation:Project"
             x:Name="Root"
             Background="{DynamicResource Editor.Window.GrayBrush2}">

    <UserControl.Styles>
        <!-- Rows stretch so per-item action buttons can dock to the right edge -->
        <Style Selector="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <!-- Compact inline action buttons used in headers and rows -->
        <Style Selector="Button.inline">
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="30,*">

        <!-- Panel header: title + toolbar actions -->
        <Border Grid.Row="0"
                Background="{DynamicResource Editor.Window.GrayBrush2}"
                BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <Button DockPanel.Dock="Right"
                        Classes="inline"
                        Command="{Binding AddSceneCommand}">
                    Add Scene
                </Button>
                <TextBlock Text="PROJECT LAYOUT"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Editor.Window.GrayBrush6}"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Visible">
            <ItemsControl ItemsSource="{Binding Scenes}" Margin="6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="foundation:Scene">
                        <Expander IsExpanded="{Binding IsActive, Mode=OneWay}"
                                  MinWidth="200"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                        <Button Classes="inline"
                                                IsEnabled="{Binding IsActive}"
                                                Command="{Binding AddGameObjectCommand}">Add GameObject</Button>
                                        <Button Classes="inline"
                                                Command="{Binding DataContext.RemoveSceneCommand, ElementName=Root}"
                                                CommandParameter="{Binding}">Remove</Button>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                </DockPanel>
                            </Expander.Header>
                            <ListBox IsEnabled="{Binding IsActive}"
                                     ItemsSource="{Binding GameObjects}"
                                     Background="{DynamicResource Editor.Window.GrayBrush2}"
                                     BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                                     Margin="4"
                                     SelectionChanged="OnGameObjectListSelectionChanged"
                                     SelectionMode="Multiple">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="components:GameObject">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Classes="inline"
                                                    Command="{Binding ParentScene.RemoveGameObjectCommand}"
                                                    CommandParameter="{Binding}">Remove</Button>
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
