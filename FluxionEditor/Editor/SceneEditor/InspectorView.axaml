<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="using:FluxionEditor.Foundation.Components"
             xmlns:resources="using:FluxionEditor.Foundation.Resources"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FluxionEditor.InspectorView"
             x:DataType="components:MSGameObject"
             Background="{StaticResource Editor.Window.GrayBrush2}">

    <ScrollViewer VerticalScrollBarVisibility="Visible"
                  HorizontalScrollBarVisibility="Disabled"
                  IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel>
            <!-- Add Component button -->
            <Border Height="40">
                <ToggleButton HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Content="Add Component">
                    <ToggleButton.Content>
                        <DockPanel>
                            <TextBlock Text="Add Component" Margin="5,0"/>
                            <Path Margin="3,0,2,0"
                                  Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 Z"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </DockPanel>
                    </ToggleButton.Content>
                </ToggleButton>
            </Border>

            <!-- Name + Enabled -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Name:" Grid.Column="0"
                           Margin="5,0,0,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Name, Mode=OneWay}"
                         Grid.Column="1"
                         Margin="0,0,0,8" VerticalAlignment="Center"
                         resources:TextBoxCommand.Command="{Binding RenameCommand}"
                         resources:TextBoxCommand.EscCommand="{Binding CancelEditCommand}"/>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center">Enabled</TextBlock>
                    <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                              Margin="5,0,0,0" VerticalAlignment="Center"
                              Command="{Binding IsEnabledCommand}"
                              CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"/>
                </StackPanel>
            </Grid>

            <!-- Components list -->
            <TextBlock VerticalAlignment="Center" Text="Components:"/>
            <ItemsControl ItemsSource="{Binding Components}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="components:Component">
                        <TextBlock Text="{Binding Owner}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
