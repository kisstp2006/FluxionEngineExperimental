<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="foundation:Project"
             x:Class="FluxionEditor.UndoRedoList"
             Background="{DynamicResource Editor.Window.GrayBrush3}">

    <!-- Undo and redo stacks split the available height evenly -->
    <Grid RowDefinitions="Auto,*,Auto,*" Margin="8">

        <!-- ===== UNDO STACK ===== -->
        <TextBlock Grid.Row="0"
                   Text="UNDO"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                   Margin="2,0,0,4"/>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding UndoRedo.UndoStack}"
                 Background="{DynamicResource Editor.Window.GrayBrush2}"
                 BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                 MinHeight="60">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="utilities:IUndoRedo">
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ===== REDO STACK ===== -->
        <TextBlock Grid.Row="2"
                   Text="REDO"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                   Margin="2,8,0,4"/>
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding UndoRedo.RedoStack}"
                 Background="{DynamicResource Editor.Window.GrayBrush2}"
                 BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                 MinHeight="60">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="utilities:IUndoRedo">
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
