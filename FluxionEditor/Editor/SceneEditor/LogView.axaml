<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FluxionEditor.LogView"
             Background="{DynamicResource Editor.Window.GrayBrush3}">

    <UserControl.Resources>
        <utilities:SeverityToBrushConverter x:Key="LevelToBrushConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="DockPanel.logRow">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="DockPanel.logRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Toolbar — slightly darker strip inset into the panel -->
        <Border Grid.Row="0" Height="32"
                Background="{DynamicResource Editor.Window.GrayBrush2}"
                BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                BorderThickness="0,0,0,1">
            <StackPanel Margin="6,0" Orientation="Horizontal" Spacing="8">
                <Button Content="Clear"
                        Padding="10,1" MinHeight="20" FontSize="11"
                        VerticalAlignment="Center"
                        Click="OnClearButtonClick"/>
                <!-- Vertical separator between action and filters -->
                <Border Width="1" Margin="0,7"
                        Background="{DynamicResource Editor.Window.GrayBrush4}"/>
                <CheckBox x:Name="InfoCheckBox"    Content="Info"  IsChecked="True" Click="OnFilterCheckBoxClick"/>
                <CheckBox x:Name="WarningCheckBox" Content="Warn"  IsChecked="True" Click="OnFilterCheckBoxClick"/>
                <CheckBox x:Name="ErrorCheckBox"   Content="Error" IsChecked="True" Click="OnFilterCheckBoxClick"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="LogItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="utilities:MessageLog">
                        <DockPanel Classes="logRow"
                                   ToolTip.Tip="{Binding MetaData}"
                                   Margin="2,1">
                            <!-- Color-coded time (fixed width so messages align) -->
                            <TextBlock Text="{Binding Time, StringFormat={}{0:HH:mm:ss}}"
                                       Foreground="{Binding Level, Converter={StaticResource LevelToBrushConverter}}"
                                       Margin="4,1"
                                       Width="58"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       VerticalAlignment="Top"/>
                            <!-- Level tag (same color, fixed width column) -->
                            <TextBlock Text="{Binding Level}"
                                       Foreground="{Binding Level, Converter={StaticResource LevelToBrushConverter}}"
                                       Margin="2,1"
                                       Width="48"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Top"/>
                            <!-- Message with wrapping -->
                            <TextBlock Text="{Binding Log}"
                                       Foreground="{Binding Level, Converter={StaticResource LevelToBrushConverter}}"
                                       Margin="6,1"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
