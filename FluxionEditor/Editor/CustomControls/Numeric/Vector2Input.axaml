<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:numeric="using:FluxionEditor.Editor.CustomControls.Numeric"
             x:Class="FluxionEditor.Editor.CustomControls.Numeric.Vector2Input"
             x:Name="Root">

    <!-- Header takes only what it needs (Auto); the fields split the rest
         evenly (*), so they stretch to fill all available width. -->
    <Grid VerticalAlignment="Center" ColumnDefinitions="Auto,*,*">
        <TextBlock Grid.Column="0"
                   Text="{Binding Header, ElementName=Root}"
                   Width="65"
                   Margin="0,0,6,0"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   FontSize="12"
                   IsVisible="{Binding Header, ElementName=Root, Converter={x:Static ObjectConverters.IsNotNull}}"/>

        <numeric:NumberBox Grid.Column="1" Label="X" Margin="0,0,6,0"
                           Value="{Binding X, ElementName=Root}"/>
        <numeric:NumberBox Grid.Column="2" Label="Y"
                           Value="{Binding Y, ElementName=Root}"/>
    </Grid>

</UserControl>
