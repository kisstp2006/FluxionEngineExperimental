<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:numeric="using:FluxionEditor.Editor.CustomControls.Numeric"
             x:Class="FluxionEditor.Editor.CustomControls.Numeric.Vector4Input"
             x:Name="Root">

    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
        <!-- Property name on the left (Unity-style: left-aligned, fixed column) -->
        <TextBlock Grid.Column="0"
                   Text="{Binding Header, ElementName=Root}"
                   Width="65"
                   VerticalAlignment="Center"
                   TextAlignment="Left"
                   FontSize="12"
                   IsVisible="{Binding Header, ElementName=Root, Converter={x:Static ObjectConverters.IsNotNull}}"/>

        <!-- X / Y / Z / W fields, evenly distributed and each preceded by its axis letter -->
        <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*">
            <TextBlock Grid.Column="0" Classes="AxisLabel" Text="X"/>
            <numeric:NumberBox Grid.Column="1" Value="{Binding X, ElementName=Root}" Margin="0,0,6,0"/>

            <TextBlock Grid.Column="2" Classes="AxisLabel" Text="Y"/>
            <numeric:NumberBox Grid.Column="3" Value="{Binding Y, ElementName=Root}" Margin="0,0,6,0"/>

            <TextBlock Grid.Column="4" Classes="AxisLabel" Text="Z"/>
            <numeric:NumberBox Grid.Column="5" Value="{Binding Z, ElementName=Root}" Margin="0,0,6,0"/>

            <TextBlock Grid.Column="6" Classes="AxisLabel" Text="W"/>
            <numeric:NumberBox Grid.Column="7" Value="{Binding W, ElementName=Root}"/>
        </Grid>
    </Grid>

</UserControl>
