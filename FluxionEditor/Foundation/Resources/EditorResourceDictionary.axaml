<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="using:FluxionEditor.Foundation.Resources">

    <!--
        TextBox with Enter-key command support.
        Usage:
          <TextBox Classes="EnterCommand"
                   Text="{Binding Name}"
                   resources:TextBoxCommand.Command="{Binding RenameCommand}"/>
    -->
    <Style Selector="TextBox.EnterCommand">
        <Setter Property="resources:TextBoxCommand.CommandParameter"
                Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Window Style                                           -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Window.FluxionWindow">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Title Bar Buttons                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Button.titleBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.titleBar:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush4}"/>
    </Style>
    <Style Selector="Button.close:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.RedBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ToggleButton – dark tab-style look                     -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="35"/>
    </Style>
    <Style Selector="ToggleButton:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush3}"/>
    </Style>
    <Style Selector="ToggleButton:checked">
        <Setter Property="Background" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton:checked:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.BlueBrush}"/>
    </Style>    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Text Drop Shadow                                       -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="TextBlock.shadow">
        <Setter Property="Effect">
            <DropShadowEffect BlurRadius="3"
                              Opacity="0.4"
                              Color="Black"/>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Global Text Styles                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush3}"/>
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="SelectionForegroundBrush" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Editor.Window.GrayBrush5}"/>
        <Setter Property="Padding" Value="4,3"/>
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Button                                                  -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush4}"/>
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Editor.Window.GrayBrush5}"/>
        <Setter Property="Padding" Value="10,4"/>
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Editor.BlueBrush}"/>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush3}"/>
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Foreground" Value="{StaticResource Editor.Disabled.FontBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ListBox + ListBoxItem                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush2}"/>
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Editor.FontBrush}"/>
        <Setter Property="Padding" Value="6,3"/>
    </Style>
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush4}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.BlueBrush}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:focus">
        <Setter Property="Background" Value="{StaticResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ScrollBar                                               -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton#PART_LineUpButton,
                     ScrollBar /template/ RepeatButton#PART_LineDownButton">
        <Setter Property="Height" Value="0"/>
        <Setter Property="Width" Value="0"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#PART_Thumb">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush5}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#PART_Thumb:pointerover">
        <Setter Property="Background" Value="{StaticResource Editor.Window.GrayBrush6}"/>
    </Style>

</Styles>