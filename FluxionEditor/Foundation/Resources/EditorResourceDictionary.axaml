<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="using:FluxionEditor.Foundation.Resources">

    <!--
        TextBox with Enter-key command support.
        Usage:
          <TextBox Classes="EnterCommand"
                   Text="{Binding Name}"
                   resources:TextBoxCommand.Command="{Binding RenameCommand}"/>
    -->
    <Style Selector="TextBox.EnterCommand">
        <Setter Property="resources:TextBoxCommand.CommandParameter"
                Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Window Style                                           -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Window.FluxionWindow">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Title Bar Buttons                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Button.titleBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.titleBar:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
    </Style>
    <Style Selector="Button.close:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.RedBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ToggleButton – dark tab-style look                     -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="ToggleButton /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="ToggleButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
    </Style>
    <Style Selector="ToggleButton:checked">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton:checked:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.BlueBrush}"/>
    </Style>
    <!-- Template-part overrides so Fluent's own state colors don't win -->
    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.BlueBrush}"/>
    </Style>    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Text Drop Shadow                                       -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="TextBlock.shadow">
        <Setter Property="Effect">
            <DropShadowEffect BlurRadius="3"
                              Opacity="0.4"
                              Color="Black"/>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Menu + MenuItem                                          -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush2}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="MenuItem:selected /template/ Border#root">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="MenuItem:selected">
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <!-- Submenu popup -->
    <Style Selector="MenuItem > Popup > Border">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="MenuItem Separator">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="8,3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- TabControl + TabItem                                     -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.Disabled.FontBrush}"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="TabItem /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="TabItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
    </Style>
    <!-- Template-part overrides so Fluent's own state colors don't win -->
    <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
    </Style>
    <!-- Blue indicator under the selected panel tab -->
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
    </Style>
    <Style Selector="TabStrip">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush2}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Expander                                                 -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Expander">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton#PART_toggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Global Text Styles                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="SelectionForegroundBrush" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="Padding" Value="4,3"/>
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="TextBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource Editor.Disabled.FontBrush}"/>
    </Style>
    <!-- Fluent applies hover/focus backgrounds on the template border directly,
         which would flash the light theme colors — override the template part. -->
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush6}"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Button                                                  -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.BlueBrush}"/>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Foreground" Value="{DynamicResource Editor.Disabled.FontBrush}"/>
    </Style>
    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <!-- Fluent sets hover/pressed colors on the content presenter directly —
         override the template part so the editor palette wins. -->
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.BlueBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.Disabled.FontBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ListBox + ListBoxItem                                   -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
        <Setter Property="Padding" Value="6,3"/>
    </Style>
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.BlueBrush}"/>
    </Style>
    <Style Selector="ListBoxItem:selected:focus">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
    </Style>
    <!-- Template-part overrides so Fluent's own state colors don't win -->
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush4}"/>
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Editor.BlueBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- GridSplitter — dark seams between panels                -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush1}"/>
    </Style>
    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Selected.BackgroundBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- CheckBox                                                -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Editor.FontBrush}"/>
    </Style>
    <Style Selector="CheckBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource Editor.Disabled.FontBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- ScrollBar                                               -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton#PART_LineUpButton,
                     ScrollBar /template/ RepeatButton#PART_LineDownButton">
        <Setter Property="Height" Value="0"/>
        <Setter Property="Width" Value="0"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#PART_Thumb">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush5}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#PART_Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource Editor.Window.GrayBrush6}"/>
    </Style>

</Styles>