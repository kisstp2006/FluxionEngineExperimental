<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Editor palette with theme variants.
        The active variant follows Application.RequestedThemeVariant,
        which is controlled by ThemeManager. Reference these keys with
        DynamicResource so controls update on a live theme switch.
    -->

    <ResourceDictionary.ThemeDictionaries>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- DARK THEME                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Dark">

            <!-- Window / panel grays: 1 = backmost, 6 = brightest -->
            <Color x:Key="Editor.Window.GrayColor1">#FF2D2D30</Color>
            <Color x:Key="Editor.Window.GrayColor2">#FF3E3E42</Color>
            <Color x:Key="Editor.Window.GrayColor3">#FF505050</Color>
            <Color x:Key="Editor.Window.GrayColor4">#FF686868</Color>
            <Color x:Key="Editor.Window.GrayColor5">#FF808080</Color>
            <Color x:Key="Editor.Window.GrayColor6">#FF999999</Color>

            <SolidColorBrush x:Key="Editor.Window.GrayBrush1" Color="{StaticResource Editor.Window.GrayColor1}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush2" Color="{StaticResource Editor.Window.GrayColor2}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush3" Color="{StaticResource Editor.Window.GrayColor3}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush4" Color="{StaticResource Editor.Window.GrayColor4}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush5" Color="{StaticResource Editor.Window.GrayColor5}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush6" Color="{StaticResource Editor.Window.GrayColor6}"/>

            <!-- Font colors -->
            <Color x:Key="Editor.FontColor">#FFDCDCDC</Color>
            <Color x:Key="Editor.Disabled.FontColor">#FF666666</Color>

            <SolidColorBrush x:Key="Editor.FontBrush" Color="{StaticResource Editor.FontColor}"/>
            <SolidColorBrush x:Key="Editor.Disabled.FontBrush" Color="{StaticResource Editor.Disabled.FontColor}"/>

            <!-- Accent colors -->
            <Color x:Key="Editor.RedColor">#FFC83030</Color>
            <Color x:Key="Editor.GreenColor">#FF30C830</Color>
            <Color x:Key="Editor.BlueColor">#FF3080C8</Color>
            <Color x:Key="Editor.OrangeColor">#FFC88030</Color>

            <SolidColorBrush x:Key="Editor.RedBrush" Color="{StaticResource Editor.RedColor}"/>
            <SolidColorBrush x:Key="Editor.GreenBrush" Color="{StaticResource Editor.GreenColor}"/>
            <SolidColorBrush x:Key="Editor.BlueBrush" Color="{StaticResource Editor.BlueColor}"/>
            <SolidColorBrush x:Key="Editor.OrangeBrush" Color="{StaticResource Editor.OrangeColor}"/>

            <!-- Selection -->
            <Color x:Key="Editor.Selected.BackgroundColor">#FF264F78</Color>
            <SolidColorBrush x:Key="Editor.Selected.BackgroundBrush" Color="{StaticResource Editor.Selected.BackgroundColor}"/>

        </ResourceDictionary>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LIGHT THEME                                         -->
        <!-- Derived from the dark ramp: 1 = backmost (darkest   -->
        <!-- light-gray), 4 = raised controls (brightest), while -->
        <!-- 5/6 provide hover/border contrast against 4.        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Light">

            <Color x:Key="Editor.Window.GrayColor1">#FFD0D0D6</Color>
            <Color x:Key="Editor.Window.GrayColor2">#FFE2E2E7</Color>
            <Color x:Key="Editor.Window.GrayColor3">#FFEDEDF1</Color>
            <Color x:Key="Editor.Window.GrayColor4">#FFFBFBFD</Color>
            <Color x:Key="Editor.Window.GrayColor5">#FFC4C9D6</Color>
            <Color x:Key="Editor.Window.GrayColor6">#FFA9AEBE</Color>

            <SolidColorBrush x:Key="Editor.Window.GrayBrush1" Color="{StaticResource Editor.Window.GrayColor1}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush2" Color="{StaticResource Editor.Window.GrayColor2}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush3" Color="{StaticResource Editor.Window.GrayColor3}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush4" Color="{StaticResource Editor.Window.GrayColor4}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush5" Color="{StaticResource Editor.Window.GrayColor5}"/>
            <SolidColorBrush x:Key="Editor.Window.GrayBrush6" Color="{StaticResource Editor.Window.GrayColor6}"/>

            <!-- Font colors -->
            <Color x:Key="Editor.FontColor">#FF1E1E1E</Color>
            <Color x:Key="Editor.Disabled.FontColor">#FF9A9AA0</Color>

            <SolidColorBrush x:Key="Editor.FontBrush" Color="{StaticResource Editor.FontColor}"/>
            <SolidColorBrush x:Key="Editor.Disabled.FontBrush" Color="{StaticResource Editor.Disabled.FontColor}"/>

            <!-- Accent colors (slightly darkened for light surfaces) -->
            <Color x:Key="Editor.RedColor">#FFB42828</Color>
            <Color x:Key="Editor.GreenColor">#FF1F9E1F</Color>
            <Color x:Key="Editor.BlueColor">#FF2268B0</Color>
            <Color x:Key="Editor.OrangeColor">#FFB06818</Color>

            <SolidColorBrush x:Key="Editor.RedBrush" Color="{StaticResource Editor.RedColor}"/>
            <SolidColorBrush x:Key="Editor.GreenBrush" Color="{StaticResource Editor.GreenColor}"/>
            <SolidColorBrush x:Key="Editor.BlueBrush" Color="{StaticResource Editor.BlueColor}"/>
            <SolidColorBrush x:Key="Editor.OrangeBrush" Color="{StaticResource Editor.OrangeColor}"/>

            <!-- Selection: stays dark enough for the white selected-text -->
            <Color x:Key="Editor.Selected.BackgroundColor">#FF3573C0</Color>
            <SolidColorBrush x:Key="Editor.Selected.BackgroundBrush" Color="{StaticResource Editor.Selected.BackgroundColor}"/>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
