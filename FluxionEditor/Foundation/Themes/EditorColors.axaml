<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Theme index: merges each theme variant from its own file in this
        folder (Dark.axaml, Light.axaml). The active variant follows
        Application.RequestedThemeVariant, which ThemeManager controls.
        Reference these keys with DynamicResource so controls update on
        a live theme switch.
    -->

    <ResourceDictionary.ThemeDictionaries>
        <ResourceInclude x:Key="Dark" Source="avares://FluxionEditor/Foundation/Themes/Dark.axaml"/>
        <ResourceInclude x:Key="Light" Source="avares://FluxionEditor/Foundation/Themes/Light.axaml"/>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
