<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FluxionEditor.OpenProjectView"
             Width="800">

    <UserControl.Resources>
        <utilities:ByteArrayToBitmapConverter x:Key="ByteToBitmapConverter"/>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource Editor.Window.GrayBrush2}">

        <!-- Footer strip: separated action bar, buttons bottom-right -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Width="90"
                        HorizontalContentAlignment="Center"
                        IsDefault="True"
                        Click="OnOpenButtonClick">Open</Button>
                <Button Width="90"
                        HorizontalContentAlignment="Center"
                        IsCancel="True">Exit</Button>
            </StackPanel>
        </Border>

        <!-- Project list + preview -->
        <Grid ColumnDefinitions="230,16,*" Margin="24,8,24,16">

            <!-- Left column: recent projects -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <TextBlock Text="RECENT PROJECTS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                           Margin="2,0,0,6"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{x:Static foundation:OpenProject.Projects}"
                         x:Name="ProjectsListBox"
                         SelectedIndex="0"
                         DoubleTapped="OnProjectDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="foundation:ProjectData">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Image Source="{Binding Icon, Converter={StaticResource ByteToBitmapConverter}}"
                                       Width="32" Height="32"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Right column: preview -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <TextBlock Text="PREVIEW"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                           Margin="2,0,0,6"/>
                <!-- Preview image: outer border = themed panel surface,
                     inner border = the screenshot itself (kept separate so the
                     DynamicResource background can't overwrite the ImageBrush) -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Editor.Window.GrayBrush3}"
                        BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True"
                        x:CompileBindings="False">
                    <Border CornerRadius="3">
                        <Border.Background>
                            <ImageBrush Source="{Binding SelectedItem.Screenshot, Converter={StaticResource ByteToBitmapConverter}, ElementName=ProjectsListBox}"/>
                        </Border.Background>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
