<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="foundation:NewProject"
             x:Class="FluxionEditor.CreateProjectView"
             Width="800">

    <UserControl.Resources>
        <utilities:ByteArrayToBitmapConverter x:Key="ByteToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <foundation:NewProject/>
    </UserControl.DataContext>

    <DockPanel Background="{DynamicResource Editor.Window.GrayBrush2}">

        <!-- Footer strip: validation error on the left, actions on the right -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Width="90"
                            HorizontalContentAlignment="Center"
                            IsDefault="True"
                            IsEnabled="{Binding IsValidProjectPath}"
                            Click="OnCreateButtonClick">Create</Button>
                    <Button Width="90"
                            HorizontalContentAlignment="Center"
                            IsCancel="True"
                            Click="OnExitButtonClick">Exit</Button>
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Editor.RedBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
            </DockPanel>
        </Border>

        <Grid RowDefinitions="*,Auto" Margin="24,8,24,16">

            <!-- Template list + preview -->
            <Grid Grid.Row="0" ColumnDefinitions="230,16,*">

                <!-- Left column: templates -->
                <Grid Grid.Column="0" RowDefinitions="Auto,*">
                    <TextBlock Text="TEMPLATES"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                               Margin="2,0,0,6"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ProjectTemplates}"
                             x:Name="TemplateList"
                             SelectedIndex="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="foundation:ProjectTemplate">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Image Source="{Binding Icon, Converter={StaticResource ByteToBitmapConverter}}"
                                           Width="32" Height="32"/>
                                    <TextBlock Text="{Binding ProjectType}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Right column: preview -->
                <Grid Grid.Column="2" RowDefinitions="Auto,*">
                    <TextBlock Text="PREVIEW"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Editor.Window.GrayBrush6}"
                               Margin="2,0,0,6"/>
                    <!-- Preview image: outer border = themed panel surface,
                         inner border = the screenshot itself (kept separate so the
                         DynamicResource background can't overwrite the ImageBrush) -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource Editor.Window.GrayBrush3}"
                            BorderBrush="{DynamicResource Editor.Window.GrayBrush4}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True"
                            x:CompileBindings="False">
                        <Border CornerRadius="3">
                            <Border.Background>
                                <ImageBrush Source="{Binding SelectedItem.Screenshot, Converter={StaticResource ByteToBitmapConverter}, ElementName=TemplateList}"/>
                            </Border.Background>
                        </Border>
                    </Border>
                </Grid>
            </Grid>

            <!-- Name / Path inputs -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="52,*"
                  RowDefinitions="Auto,8,Auto"
                  Margin="0,16,0,0">

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Name"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ProjectName}"
                         Watermark="My Project"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Path"
                           VerticalAlignment="Center"/>
                <DockPanel Grid.Row="2" Grid.Column="1">
                    <Button DockPanel.Dock="Right"
                            Width="75" Margin="8,0,0,0"
                            HorizontalContentAlignment="Center"
                            VerticalAlignment="Stretch">Browse</Button>
                    <TextBox Text="{Binding ProjectPath}"
                             Watermark="C:\Projects"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
