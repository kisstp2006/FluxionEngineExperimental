<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="foundation:NewProject"
             x:Class="FluxionEditor.CreateProjectView"
             Width="800">

    <UserControl.Resources>
        <utilities:ByteArrayToBitmapConverter x:Key="ByteToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <foundation:NewProject/>
    </UserControl.DataContext>

    <StackPanel Background="{StaticResource Editor.Window.GrayBrush2}">
        <!-- Template list + preview -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <ListBox Width="200" Height="250"
                     ItemsSource="{Binding ProjectTemplates}"
                     x:Name="TemplateList"
                     SelectedIndex="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="foundation:ProjectTemplate">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Icon, Converter={StaticResource ByteToBitmapConverter}}"
                                   Width="32" Height="32" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ProjectType}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!-- Preview image -->
            <Border Width="480" Height="250" Margin="5,0,0,0"
                    Background="{StaticResource Editor.Window.GrayBrush3}"
                    BorderBrush="{StaticResource Editor.Window.GrayBrush4}"
                    BorderThickness="1"
                    x:CompileBindings="False">
                <Border.Background>
                    <ImageBrush Source="{Binding SelectedItem.Screenshot, Converter={StaticResource ByteToBitmapConverter}, ElementName=TemplateList}"/>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Name / Path inputs -->
        <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
            <!-- Name row -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left"
                           Text="Name" Width="50"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding ProjectName}"/>
            </DockPanel>
            <!-- Path row -->
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Width="75" Margin="5,0,0,0"
                        VerticalAlignment="Stretch">Browse</Button>
                <TextBlock DockPanel.Dock="Left"
                           Text="Path" Width="50"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding ProjectPath}"/>
            </DockPanel>
        </StackPanel>

        <!-- Action buttons + error -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Width="100" IsDefault="True"
                    IsEnabled="{Binding IsValidProjectPath}"
                    Click="OnCreateButtonClick">Create</Button>
            <Button Width="100" Margin="20,0,0,0"
                    IsCancel="True"
                    Click="OnExitButtonClick">Exit</Button>
        </StackPanel>
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource Editor.RedBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>
