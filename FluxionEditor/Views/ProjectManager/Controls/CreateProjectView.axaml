<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:utilities="using:FluxionEditor.Foundation.Utilities"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:metadata="using:System.Reflection.Metadata"
             xmlns:reflection="using:System.Reflection"
             xmlns:system="using:System"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="foundation:NewProject"
             x:Class="FluxionEditor.CreateProjectView"
             Width="800">

    <UserControl.Resources>
        <utilities:ByteArrayToBitmapConverter x:Key="ByteToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <foundation:NewProject></foundation:NewProject>
    </UserControl.DataContext>
  
    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ListBox Width="200" Height="250" ItemsSource="{Binding ProjectTemplates}" x:Name="template_list" SelectedIndex="0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="foundation:ProjectTemplate">
                        <StackPanel Orientation="Horizontal">
                           <Image Source="{Binding Icon, Converter={StaticResource ByteToBitmapConverter}}" Width="32" Height="32" Margin="0,0,5,0"></Image>
                            <TextBlock Text="{Binding ProjectType}" VerticalAlignment="Center"></TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Background="DimGray" Width="480" Height="250" Margin="5,0,0,0"
                    x:CompileBindings="False">
                <Border.Background>
                    <ImageBrush Source="{Binding SelectedItem.Screenshot, Converter={StaticResource ByteToBitmapConverter}, ElementName=template_list}"></ImageBrush>
                </Border.Background>
            </Border>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <TextBlock Text="Name" Width="50" VerticalAlignment="Center"></TextBlock>
            <TextBox Width="550" Text="{Binding ProjectName}"></TextBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Path" Width="50" VerticalAlignment="Center"></TextBlock>
            <TextBox Width="470" Text="{Binding ProjectPath}"></TextBox>
            <Button Width="75" Margin="5,0,0,0">Browse</Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button Width="100" IsDefault="True">Create</Button>
            <Button Width="100" Margin="30,0,0,0" IsCancel="True">Exit</Button>
        </StackPanel>
    </StackPanel>
</UserControl>
