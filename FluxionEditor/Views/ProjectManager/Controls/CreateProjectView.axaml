<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:foundation="using:FluxionEditor.Foundation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:metadata="using:System.Reflection.Metadata"
             xmlns:reflection="using:System.Reflection"
             xmlns:system="using:System"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="foundation:NewProject"
             x:Class="FluxionEditor.CreateProjectView"
             Width="800">

    <UserControl.DataContext>
        <foundation:NewProject></foundation:NewProject>
    </UserControl.DataContext>
  
    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ListBox Width="200" Height="250"></ListBox>
            <Border Background="DimGray" Width="480" Height="250" Margin="5,0,0,0"></Border>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <TextBlock Text="Name" Width="50" VerticalAlignment="Center"></TextBlock>
            <TextBox Width="550" Text="{Binding Name}"></TextBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Path" Width="50" VerticalAlignment="Center"></TextBlock>
            <TextBox Width="470" Text="{Binding Path}"></TextBox>
            <Button Width="75" Margin="5,0,0,0">Browse</Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button Width="100" IsDefault="True">Create</Button>
            <Button Width="100" Margin="30,0,0,0" IsCancel="True">Exit</Button>
        </StackPanel>
    </StackPanel>
</UserControl>
