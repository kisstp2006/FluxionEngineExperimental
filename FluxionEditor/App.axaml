<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FluxionEditor.App"
             xmlns:local="using:FluxionEditor"
             RequestedThemeVariant="Dark"
             >
             <!-- Dark: the editor palette is a dark theme — Fluent's own surfaces
                  (popups, tooltips, flyouts) must match it regardless of OS theme. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FluxionEditor/Foundation/Themes/EditorColors.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://FluxionEditor/Foundation/Resources/EditorResourceDictionary.axaml"/>
        <StyleInclude Source="avares://FluxionEditor/Editor/CustomControls/Numeric/NumericInput.axaml"/>
    </Application.Styles>
</Application>